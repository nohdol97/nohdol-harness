#!/bin/sh
# tdd-gate의 유일한 실행 계층 — 전역 core.hooksPath가 이 디렉토리를 가리킨다 (ADR 014·015).
# Claude Code·Codex·수동 커밋 등 도구와 무관하게 같은 게이트가 걸리게 하는 진입점이다.
# 인터프리터 탐색은 실행 확인(-c "")으로 판별한다(스펙 R6) — Windows Store 스텁을
# 걸러내고, 파이썬이 없으면 게이트 없이 통과한다(fail-open).
HERE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GATE="$HERE/tdd-gate.py"
# 게이트 스크립트 부재(하네스 이동·삭제)가 머신 전역의 커밋을 막으면 안 된다(R4 fail-open) —
# 인터프리터의 "파일 없음" exit 2는 게이트 차단과 구분되지 않으므로 존재를 먼저 확인한다.
[ -f "$GATE" ] || exit 0
rc=0
for p in python3 python py; do
    if "$p" -c "" >/dev/null 2>&1; then
        "$p" "$GATE" --commit-msg "$1"
        rc=$?
        break
    fi
done
# 게이트의 의도적 차단(exit 65)만 커밋을 막는다. 그 외 비0 rc는 게이트 자체의
# 오류다 — 스크립트 손상 시 인터프리터가 rc 1(SyntaxError)·2(열기 실패)로 죽는데,
# 이를 차단으로 전파하면 머신 전역 커밋이 막히고 게이트 수정 커밋조차 막힌다(R4 fail-open).
[ "$rc" -eq 65 ] && exit 1
# 전역 hooksPath는 저장소 로컬 훅(.git/hooks)을 가리므로 같은 이름의 로컬 훅에 체인한다.
# `--git-path hooks/`는 core.hooksPath를 따라 자기 자신을 돌려주므로 쓰지 않는다(무한 재귀).
gd=$(git rev-parse --git-dir 2>/dev/null) || exit 0
[ -x "$gd/hooks/commit-msg" ] && exec "$gd/hooks/commit-msg" "$@"
exit 0
